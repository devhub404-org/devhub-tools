---
import BaseLayout from "../layouts/BaseLayout.astro"
import ToolCard from "../components/ToolCard"
import { getTools } from "../registry"

const tools = getTools()
---

<BaseLayout title="DevHub 404 Tools">
  <section class="home-hero">
    <p class="hero-label">// ferramentas</p>
    <h1 class="hero-title">DevHub 404 Tools</h1>
    <p class="hero-sub">
      Utilitários para devs — sem distrações, sem cadastro, sem frescura.
    </p>
  </section>

  <section class="tools-grid" id="tools">
    {tools.length === 0 ? (
      <p class="empty-state">Nenhuma ferramenta registrada ainda.</p>
    ) : (
      tools.map((tool) => (
        <ToolCard tool={tool} />
      ))
    )}
  </section>
</BaseLayout>